# J.A.R.V.I.S. Environment Configuration Template
# 
# Copy this file to .env and fill in your API keys and settings.
# This file should NEVER be committed to version control (add to .gitignore).
#
# Setup:
#   1. Copy this file: cp .env.example .env
#   2. Add your API keys below
#   3. Restart J.A.R.V.I.S. to load new settings
#
# All settings are optional except OPENAI_API_KEY (required for AI features)

# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED: OpenAI API Key
# ═══════════════════════════════════════════════════════════════════════════

# Your OpenAI API key for GPT-4o access
# Get it from: https://platform.openai.com/api-keys
# Required: Yes (without this, J.A.R.V.I.S. cannot function)
OPENAI_API_KEY=sk-proj-your-api-key-here

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: Fury SDK Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Fury SDK API key for framework access
# Get it from: https://fury.cloud
# Required: No (only if using Fury Cloud services)
# FURY_API_KEY=your-fury-api-key-here

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: Google OAuth2 Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Google API credentials file location
# Generate from: https://console.cloud.google.com/apis/credentials
# Format: JSON downloaded from Google Cloud Console
# Note: File is auto-generated on first run if missing
# GOOGLE_CREDENTIALS_FILE=credentials.json

# Gmail token cache location (auto-generated, do not edit)
# GMAIL_TOKEN_FILE=gmail_token.json

# Calendar token cache location (auto-generated, do not edit)
# CALENDAR_TOKEN_FILE=token.json

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: Audio Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Audio input device index (0 = default microphone)
# Find device index: python -m sounddevice
# AUDIO_INPUT_DEVICE=0

# Audio output device index (0 = default speakers)
# AUDIO_OUTPUT_DEVICE=0

# Audio recording sample rate (Hz)
# Default: 16000 (optimal for Whisper STT)
# AUDIO_INPUT_SAMPLE_RATE=16000

# Audio playback sample rate (Hz)
# Default: 24000 (standard for TTS)
# AUDIO_OUTPUT_SAMPLE_RATE=24000

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: GPU/CUDA Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Enable GPU acceleration for Whisper (requires CUDA-capable NVIDIA GPU)
# Default: auto-detect
# Options: auto | cuda | cpu
# GPU_DEVICE=auto

# Whisper model compute type (float16 is faster, float32 is more accurate)
# Default: float16 (7-9x faster on GPU)
# Options: float16 | float32
# WHISPER_COMPUTE_TYPE=float16

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: Web Server Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Access token for multi-device security (optional but recommended for external access)
# Set any strong password — share only with trusted devices
# Without this, anyone on the network can connect (fine for home LAN)
# Usage: bookmark http://host:4444?token=YOUR_TOKEN — stored in browser localStorage
# JARVIS_TOKEN=your-secret-token-here

# Web server port (default: 4444)
# Access at: http://localhost:4444
# WEB_PORT=4444

# Web server host (0.0.0.0 = accessible from any network interface)
# Default: 0.0.0.0 (recommended)
# Options: 0.0.0.0 | localhost | 127.0.0.1 | your-ip
# WEB_HOST=0.0.0.0

# Enable hot-reload on code changes (development only)
# Default: True
# WEB_RELOAD=True

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: Logging Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Log level for console output
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
# LOG_LEVEL=INFO

# Enable file logging
# Default: False
# FILE_LOGGING=False

# Log file location
# LOG_FILE=jarvis.log

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: Memory & History Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Conversation history storage location
# Default: .fury/memory
# MEMORY_PATH=.fury/memory

# Maximum conversation history tokens to keep
# Default: 128000 (GPT-4o context window)
# CONTEXT_WINDOW=128000

# Reserve tokens to prevent hitting token limits
# Default: 2048
# RESERVE_TOKENS=2048

# Keep recent tokens for short-term memory
# Default: 4000 (to stay under OpenAI TPM limits)
# KEEP_RECENT_TOKENS=4000

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: Personality & System Prompt
# ═══════════════════════════════════════════════════════════════════════════

# User name (used in system prompt)
# Default: Yaseen
# USER_NAME=Yaseen

# Custom system prompt file (overrides default)
# Leave commented to use default J.A.R.V.I.S. personality
# SYSTEM_PROMPT_FILE=custom_prompt.txt

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: Tool Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Enable/disable specific tool suites
# Default: True (all enabled)
# ENABLE_WEB_TOOLS=True
# ENABLE_CALENDAR_TOOLS=True
# ENABLE_EMAIL_TOOLS=True
# ENABLE_FILE_TOOLS=True
# ENABLE_SYSTEM_TOOLS=True
# ENABLE_MEDIA_TOOLS=True

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: Development & Debugging
# ═══════════════════════════════════════════════════════════════════════════

# Debug mode (verbose logging, skip some safety checks)
# Default: False
# DEBUG=False

# Dry-run mode (execute tool calls without actually running them)
# Default: False
# DRY_RUN=False

# Disable tool execution (for testing UI only)
# Default: False
# DISABLE_TOOLS=False

# ═══════════════════════════════════════════════════════════════════════════
# Setup Instructions
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. Get OpenAI API Key:
#    - Go to https://platform.openai.com/api-keys
#    - Create new secret key
#    - Copy and paste into OPENAI_API_KEY above
#
# 2. (Optional) Set up Google OAuth2:
#    - Go to https://console.cloud.google.com/apis/credentials
#    - Create OAuth 2.0 credentials (Desktop application)
#    - Download as JSON
#    - Save as credentials.json in project root
#    - J.A.R.V.I.S. will auto-complete OAuth flow on first use
#
# 3. Run J.A.R.V.I.S.:
#    python jarvis.py              # Desktop GUI
#    python jarvis.py --web        # Web interface
#
# ═══════════════════════════════════════════════════════════════════════════
